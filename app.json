{
  "expo": {
    "name": "Stadium Takeover",
    "slug": "stadium-takeover",
    "version": "1.1.3",
    "orientation": "portrait",
    "icon": "./assets/images/android.png",
    "scheme": "stadiumtakeover",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/ios.png",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.stadiumtakeover.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Stadium Takeover accesses your photo library so you can choose a profile picture and upload photos or videos.",
        "NSLocationWhenInUseUsageDescription": "Stadium Takeover uses your location to send you alerts and offers for games and events near you. Your location is never tracked in the background.",
        "ITSAppUsesNonExemptEncryption": false,
        "appStoreId": "6749230185"
      },
      "appStoreUrl": "https://apps.apple.com/us/app/stadium-takeover/id6749230185"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.stadiumtakeover.app",
      "googleServicesFile": "./google-services.json",
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.stadiumtakeover.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/light-logo.png"
    },
    "plugins": [
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/light-logo.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "backgroundColor": "#00338D"
        }
      ],
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": true,
          "supportsPictureInPicture": false
        }
      ],
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": true
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Stadium Takeover uses your location to send you alerts and offers for games and events near you. Your location is never tracked in the background.",
          "locationAlwaysPermission": false,
          "locationAlwaysAndWhenInUsePermission": false,
          "isIosBackgroundLocationEnabled": false,
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.785465840386-ts6voja5vpakp8a8oeo82cm0vaetdg52"
        }
      ],
      [
        "@sentry/react-native",
        {
          "url": "https://sentry.io/",
          "project": "stadiumtakeoverapp",
          "organization": "stadium-takeover"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Stadium Takeover accesses your photo library so you can choose a profile picture and upload photos or videos.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      "expo-font",
      "expo-image",
      "expo-secure-store",
      "expo-status-bar", 
      "@react-native-firebase/app",
      "@react-native-firebase/crashlytics",
      "@react-native-firebase/perf"
    ],
    "extra": {
      "eas": {
        "projectId": "7450ae98-418f-49ed-b4e2-f78e12146d46"
      }
    },
    "owner": "stadiumtakeover"
  }
}
